class Program {
    public int main() {
        int n = 10;
        
        return Fibonacci(n);
    }

    public int Fibonacci(int n) {
        if ((n == 0) || n < 0) {
            return Fibonacci(n + 1) - 1;
        }

        if (n == 1) {
            return 1;
        }

        return Fibonacci(n - 1) + Fibonacci(n - 2);
    }
}
