class Program {
    public int main() {
        int a = 0;
        for (int i = 0; i < 10; i = i + 1) {
            a = a + i;
            if(a > 20) {
                continue;
            }
            WriteLine(a);
        }

        int b = 0;
        while (b <= 10) {
            WriteLine(b);
            b = b + 1;
            WriteLine(b);
            continue;
            WriteLine('x');
        }
        WriteLine(b);

        return a;
    }
}
