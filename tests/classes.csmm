class Test {
    public int pub_var;
    protected int prot_var;
    private int priv_var;

    public void hidden_func() {
        pub_var = 14;
    }

    public int double(int res) {
        return res * 2;
    }
}

class Program {
    public int main() {
        Test test = new Test();

        test.pub_var = 10;
        int should_be_10 = test.pub_var;

        int should_be_6 = test.double(3);

        test.hidden_func();
        test.pub_var = 100;
        return should_be_10 + should_be_6 + test.pub_var;
    }
}
