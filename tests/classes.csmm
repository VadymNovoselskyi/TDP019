class TestTest {
    public int pub_var;

    public int init() {
        pub_var = 10;
    }

    public int triple(int res) {
        return res * 3;
    }
}

class Test {
    public int pub_var;
    protected int prot_var;
    private int priv_var;

    public TestTest var;

    public void hidden_func() {
        var = new TestTest();
        var.init();
        WriteLine(var.pub_var);
        pub_var = 14;
    }

    public int double(int res) {
        return res * 2;
    }
}

class Program {
    public int main() {
        Test test = new Test();

        test.pub_var = 10;
        int should_be_10 = test.pub_var;

        int should_be_6 = test.double(3);

        test.hidden_func();
        # WriteLine(test.var.triple(5));
        test.pub_var = 100;
        return should_be_10 + should_be_6 + test.pub_var;
    }
}
